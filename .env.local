# Server-side only — KHÔNG dùng NEXT_PUBLIC_ prefix
# Browser không bao giờ biết URL này
GATEWAY_URL=http://localhost:4001

# 32-byte hex key for AES-256-GCM cookie encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_ENCRYPTION_KEY=2a1b2ce071b0bfedd22cae89e42207c131993420ccd75d5dc9ffe6651449e1ee

# Social login public keys
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_FACEBOOK_APP_ID=
